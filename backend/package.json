{
  "name": "intervene-backend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "start:dev": "tsx watch src/main.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/main.js",
    "start:stable": "npm run build && node dist/main.js",
    "rag:kb": "tsx scripts/rag-kb-builder.ts",
    "rag:kb:dry": "tsx scripts/rag-kb-builder.ts --dry-run",
    "questions:seed": "tsx scripts/seed-question-bank.ts",
    "questions:seed:dry": "tsx scripts/seed-question-bank.ts --dry-run",
    "nowcoder:crawl": "tsx scripts/nowcoder-interview-crawler.ts",
    "nowcoder:export-book": "tsx scripts/export-nowcoder-book.ts"
  },
  "dependencies": {
    "@nestjs/common": "^11.0.11",
    "@nestjs/core": "^11.0.11",
    "@nestjs/platform-express": "^11.0.11",
    "@nestjs/swagger": "^11.0.6",
    "@nestjs/typeorm": "^11.0.0",
    "docx": "^9.6.1",
    "pg": "^8.13.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "typeorm": "^0.3.21"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "cheerio": "^1.2.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  }
}
