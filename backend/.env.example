# Backend app
ENABLE_SWAGGER=true
SWAGGER_ONLY=false
MVP_SEED=false

# PostgreSQL
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_DB=intervene_app
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# LLM
LLM_ENABLED=true
LLM_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_EMBEDDING_BASE_URL=https://api.openai.com/v1
OPENAI_EMBEDDING_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_TEMPERATURE=0.2
OPENAI_TIMEOUT_MS=20000
OPENAI_RESPONSE_FORMAT=json_schema

# STT
STT_ENABLED=true
OPENAI_STT_API_KEY=
OPENAI_STT_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
OPENAI_STT_MODEL=qwen3-asr-flash-2026-02-10
OPENAI_STT_LANGUAGE=zh
OPENAI_STT_RESPONSE_FORMAT=verbose_json
OPENAI_STT_TIMEOUT_MS=20000
STT_MAX_FILE_SIZE_MB=25

# Auth
AUTH_SESSION_TTL_DAYS=7
